var langArray=["ES","DE","RU","PL"],langSite=getPageLanguage();function getPageLanguage(){var pageLanguage,pathArray=window.location.pathname.split("/"),arrIndex=langArray.indexOf(pathArray[1].toUpperCase());return pageLanguage=arrIndex>=0?langArray[arrIndex]:"EN"}$(document).ready((function(){if(!isCookieSet("c_consent")){var iPath="interfaces/load-cookie-banner.php",rootPath=getRootPath();$.post(rootPath+iPath+"?lang_site="+langSite).done((function(data){var dataArr=JSON.parse(data),htmlNode=createHTMLNode(dataArr[0],dataArr[1]);document.body.appendChild(htmlNode),document.getElementById("accept-cookies").addEventListener("click",(function(){$(".cookie-banner").removeClass("show-banner"),setCookie("c_consent","1")})),setTimeout((function(){$(".cookie-banner").addClass("show-banner")}),1e3)}))}function createHTMLNode(html,content){var placeholder=document.createElement("div");placeholder.innerHTML=html;var node=placeholder.firstChild,pContent=content.p+node.getElementsByTagName("p")[0].innerHTML;node.getElementsByTagName("p")[0].innerHTML=pContent;var spanContent=content.span+" "+node.getElementsByTagName("span")[0].innerHTML;node.getElementsByTagName("span")[0].innerHTML=spanContent;var aContent=content.a+node.getElementsByTagName("a")[0].innerHTML;return node.getElementsByTagName("a")[0].innerHTML=aContent,node.getElementsByClassName("content")[0].lastChild.innerHTML=content.button,node}function getRootPath(){var rootPathArr=window.location.pathname.split("/");if(2==rootPathArr.length)rootPath="./";else{rootPath="../";for(var i=1;i<rootPathArr.length-2;i++)rootPath+="../"}return rootPath}function setCookie(cname,cvalue,exdays=90){var d=new Date;d.setTime(d.getTime()+24*exdays*60*60*1e3);var expires="expires="+d.toUTCString();document.cookie=cname+"="+cvalue+";"+expires+";path=/"}function deleteCookie(cname){document.cookie=cname+"=;expires=Thu, 01 Jan 1970 00:00:01 GMT;path=/"}function updateCookie(cname,cvalue,exdays=90){var cookieVal=getCookie(cname);if(""!=cookieVal){cookieVal+=","+cvalue;var d=new Date;d.setTime(d.getTime()+24*exdays*60*60*1e3);var expires="expires="+d.toUTCString();document.cookie=cname+"="+cookieVal+";"+expires+";path=/"}}function getCookie(cname){for(var name=cname+"=",ca=document.cookie.split(";"),i=0;i<ca.length;i++){for(var c=ca[i];" "==c.charAt(0);)c=c.substring(1);if(0==c.indexOf(name))return c.substring(name.length,c.length)}return""}function isCookieSet(cname){var cookie;return""!=getCookie(cname)}}));